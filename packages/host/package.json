{
  "name": "@agent_bridge/host",
  "version": "0.1.1",
  "description": "Host SDK for AgentBridge — mount and communicate with AI-generated guest apps via iframe or code injection",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ziyu/agent-bridge.git",
    "directory": "packages/host"
  },
  "keywords": [
    "agent",
    "bridge",
    "iframe",
    "sandbox",
    "ai",
    "llm",
    "tool-calling",
    "postmessage"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent_bridge/protocol": "workspace:*",
    "@agent_bridge/shared": "workspace:*",
    "@agent_bridge/transport-postmessage": "workspace:*"
  }
}
