{
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist",
    "pretest": "pnpm -r build",
    "examples": "pnpm run build && npx serve . -l 3000 --no-clipboard",
    "example:01": "pnpm run build && npx serve . -l 3000 --no-clipboard -o /examples/01-basic-inline/index.html",
    "example:02": "pnpm run build && npx serve . -l 3000 --no-clipboard -o /examples/02-iframe-mode/host.html",
    "example:03": "pnpm run build && npx serve . -l 3000 --no-clipboard -o /examples/03-llm-tool-calling/index.html"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "jsdom": "^28.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
